# Google API ключ для Gemini классификации
# Получите ключ на https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Инструкции:
# 1. Скопируйте этот файл в .env
# 2. Замените your_google_api_key_here на ваш реальный API ключ
# 3. Перезапустите приложение

# Примечание: Google Gemini бесплатно для использования и дает точные результаты!
